# ID del Google Spreadsheet (está en la URL: /d/ESTE_VALOR/edit)
SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Contenido completo del JSON de la Service Account (pegar todo el JSON en una línea)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Puerto (Railway lo asigna automáticamente, no tocar en producción)
PORT=3000
